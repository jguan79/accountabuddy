{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "jsx": "react-jsx",
        "strict": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "./",
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "app/**/*.ts",
        "app/**/*.tsx",
        "env.d.ts",
        "expo-env.d.ts",
        ".expo/types/**/*.ts"
    ],
    "extends": "expo/tsconfig.base"
}
